# load filenames
test_noisy_files = []
test_clean_files = []

# Build a mapping from filename to full path for clean files
clean_file_map = {}
for filename in os.listdir(test_noise_dir):
    if filename.endswith(".wav"):
        test_noisy_files.append(os.path.join(test_noise_dir, filename))
for filename in os.listdir(test_clean_dir):
    if filename.endswith(".wav"):
        clean_file_map[filename] = os.path.join(test_clean_dir, filename)

# Match clean files to noisy files by filename
test_clean_files = []
for noisy_path in test_noisy_files:
    filename = os.path.basename(noisy_path)
    if filename in clean_file_map:
        test_clean_files.append(clean_file_map[filename])
    else:
        raise ValueError(f"No matching clean file for {filename}")
        
